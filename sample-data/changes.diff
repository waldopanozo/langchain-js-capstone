@@ -0,0 +1,48 @@
+using System.Collections.Concurrent;
+
+namespace InterviewScheduling.Api.Middleware;
+
+public sealed class RateLimitMiddleware
+{
+    private readonly RequestDelegate _next;
+    private readonly int _maxRequests;
+    private readonly TimeSpan _window;
+    private readonly ConcurrentDictionary<string, Queue<DateTime>> _buckets = new();
+
+    public RateLimitMiddleware(RequestDelegate next, IConfiguration config)
+    {
+        _next = next;
+        _maxRequests = config.GetValue("RateLimit:MaxRequests", 30);
+        _window = TimeSpan.FromMinutes(config.GetValue("RateLimit:WindowMinutes", 1));
+    }
+
+    public async Task InvokeAsync(HttpContext context)
+    {
+        if (!HttpMethods.IsPost(context.Request.Method) ||
+            !context.Request.Path.StartsWithSegments("/api/bookings"))
+        {
+            await _next(context);
+            return;
+        }
+
+        var key = context.Connection.RemoteIpAddress?.ToString() ?? "unknown";
+        var now = DateTime.UtcNow;
+        var queue = _buckets.GetOrAdd(key, _ => new Queue<DateTime>());
+
+        lock (queue)
+        {
+            while (queue.Count > 0 && now - queue.Peek() > _window)
+                queue.Dequeue();
+
+            if (queue.Count >= _maxRequests)
+            {
+                context.Response.StatusCode = StatusCodes.Status429TooManyRequests;
+                context.Response.Headers.RetryAfter = ((int)_window.TotalSeconds).ToString();
+                return;
+            }
+
+            queue.Enqueue(now);
+        }
+
+        await _next(context);
+    }
+}
